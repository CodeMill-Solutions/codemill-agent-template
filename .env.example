# ─────────────────────────────────────────────────────────────────────────────
# CodeMill OpenClaw Agent — environment variables
# Copy this file to .env and fill in all values.
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# API key for the Azure OpenAI resource.
AZURE_OPENAI_API_KEY=

# Full endpoint URL, e.g. https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Name of the deployed model (e.g. gpt-4o, gpt-4-turbo).
AZURE_OPENAI_DEPLOYMENT_NAME=

# ── Yuki (boekhoudkoppeling) ──────────────────────────────────────────────────
# API key voor de Yuki REST API.
YUKI_API_KEY=

# Domain / administratie ID (GUID) van de klant in Yuki.
YUKI_DOMAIN_ID=

# ── Brave Search ──────────────────────────────────────────────────────────────
# API key van https://brave.com/search/api/
BRAVE_API_KEY=

# ── Gmail ─────────────────────────────────────────────────────────────────────
# OAuth 2.0 client credentials. Maak aan via Google Cloud Console →
# APIs & Services → Credentials → OAuth 2.0 Client IDs.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Offline refresh token voor de mailbox van de klant.
# Verkrijg via de OAuth2 consent flow (zie docs/onboarding-klant.md).
GMAIL_REFRESH_TOKEN=

# ── Google Workspace ──────────────────────────────────────────────────────────
# Absoluut pad naar het service-account sleutelbestand (JSON), bijv.:
#   /Users/<user>/codemill-agent/credentials/google-service-account.json
# Zet dit bestand NOOIT in git.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# Primair domein van de Google Workspace omgeving (bijv. bedrijf.nl).
GOOGLE_WORKSPACE_DOMAIN=

# E-mailadres van de admin die door het service-account wordt geïmpersoneerd.
GOOGLE_WORKSPACE_ADMIN_EMAIL=
